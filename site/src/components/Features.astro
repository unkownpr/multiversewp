---
import { useTranslations } from '../i18n/utils';
import type { Lang, Key } from '../i18n/ui';

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = useTranslations(lang);

const items: Array<{ icon: string; tKey: Key; dKey: Key }> = [
  { icon: '👥', tKey: 'f.multi.t', dKey: 'f.multi.d' },
  { icon: '🤖', tKey: 'f.mcp.t', dKey: 'f.mcp.d' },
  { icon: '🗄️', tKey: 'f.local.t', dKey: 'f.local.d' },
  { icon: '🔔', tKey: 'f.menubar.t', dKey: 'f.menubar.d' },
  { icon: '💬', tKey: 'f.notify.t', dKey: 'f.notify.d' },
  { icon: '🌐', tKey: 'f.bilingual.t', dKey: 'f.bilingual.d' },
  { icon: '🟢', tKey: 'f.presence.t', dKey: 'f.presence.d' },
  { icon: '🔍', tKey: 'f.search.t', dKey: 'f.search.d' },
  { icon: '✨', tKey: 'f.update.t', dKey: 'f.update.d' },
];
---

<section id="features" class="relative py-24 sm:py-32">
  <div class="mx-auto max-w-6xl px-6">
    <div class="text-center max-w-2xl mx-auto">
      <h2 class="text-3xl sm:text-4xl font-bold tracking-tight text-white">{t('features.heading')}</h2>
      <p class="mt-3 text-white/60">{t('features.sub')}</p>
    </div>

    <div class="mt-14 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {items.map((it) => (
        <div class="bubble border border-white/5 hover:border-wa-green/30 transition group">
          <div class="text-2xl mb-3" aria-hidden="true">{it.icon}</div>
          <h3 class="text-white font-semibold tracking-tight">{t(it.tKey)}</h3>
          <p class="mt-2 text-sm text-white/60 leading-relaxed">{t(it.dKey)}</p>
        </div>
      ))}
    </div>
  </div>
</section>
